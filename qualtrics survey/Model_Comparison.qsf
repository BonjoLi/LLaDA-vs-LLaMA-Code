QuestionDescriptionOption":"UseText"},"QuestionDescription":"What line of work are you in (if any)?","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID40"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID41","SecondaryAttribute":"If you are comfortable, what religion do you identify as?","TertiaryAttribute":null,"Payload":{"QuestionText":"If you are comfortable, what religion do you identify as?","DefaultChoices":false,"DataExportTag":"Q27","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If you are comfortable, what religion do you identify as?","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID41"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID42","SecondaryAttribute":"What gender do you identify as?","TertiaryAttribute":null,"Payload":{"QuestionText":"What gender do you identify as?","DefaultChoices":false,"DataExportTag":"Q28","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What gender do you identify as?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Non-binary"},"9":{"Display":"Other"}},"ChoiceOrder":["1","2","3","9"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":10,"NextAnswerId":1,"QuestionID":"QID42"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID43","SecondaryAttribute":"What is your Prolific ID? (You will need this again later in this study.)","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your Prolific ID? (You will need this again later in this study.)","DefaultChoices":false,"DataExportTag":"Q29","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your Prolific ID? (You will need this again later in this study.)","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID43"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"You are invited to take part in a research study involving a interaction with and evaluation of A...","TertiaryAttribute":null,"Payload":{"QuestionText":"You are invited to take part in a research study involving a interaction with and evaluation of AI-generated text systems. The goal of this study is to better understand how people perceive AI response quality. <br><br>If you choose to participate, you will interact with two AI text interfaces and then answer short questions about your experience. The study is expected to take approximately 15-20 minutes. <br><br>Your participation is completely voluntary. You may stop participating at any time, skip any question, or exit the survey without penalty or negative consequence. <br><br>This study involves minimal risk and is similar to everyday interactions with AI chat systems. Your responses may contribute to research on improving the design and evaluation of AI systems. <br><br>No personally identifiable information will be collected; simple demographic questions will be collected. All responses are anonymous and will be used only for research purposes, and will be destroyed after this study is completed, and aggregated results may be reported in academic papers or presentations. <br><br><b>By continuing to the next page, you confirm that you understand the information above, and that you voluntarily agree to participate in this study.<\/b>","DefaultChoices":false,"DataExportTag":"Q31","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You are invited to take part in a research study involving a interaction with and evaluation of A...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID45"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID46","SecondaryAttribute":"Thank you for completing this survey. Your Prolific completion code is CZUJCJTS.","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for completing this survey. Your Prolific completion code is&nbsp;CZUJCJTS.","DefaultChoices":false,"DataExportTag":"Q22","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for completing this survey. Your Prolific completion code is CZUJCJTS.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID46"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID47","SecondaryAttribute":"What differences did you notice between the two types of chatbot?","TertiaryAttribute":null,"Payload":{"QuestionText":"What differences did you notice between the two types of chatbot?","DefaultChoices":false,"DataExportTag":"Q23","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What differences did you notice between the two types of chatbot?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID47"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID48","SecondaryAttribute":"Are there any final thoughts you'd like to share?","TertiaryAttribute":null,"Payload":{"QuestionText":"Are there any final thoughts you'd like to share?","DefaultChoices":false,"DataExportTag":"Q24","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Are there any final thoughts you'd like to share?","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID48"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID49","SecondaryAttribute":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab. (0 =...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab.<br><br>(0 = meaningless response, 100 = perfect response)<br>","DefaultChoices":false,"DataExportTag":"Q25","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab. (0 =...","Choices":{"1":{"Display":"Prompt 1 response"},"2":{"Display":"Prompt 2 response"},"3":{"Display":"Prompt 3 response"},"4":{"Display":"Prompt 4 response"},"5":{"Display":"Prompt 5 response"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Labels":[],"QuestionID":"QID49"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab. (0 =...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab.<br><br>(0 = meaningless response, 100 = perfect response)","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Please rate the quality of the chatbot's responses to each of five prompts in the other tab. (0 =...","Choices":{"1":{"Display":"Prompt 1 response"},"2":{"Display":"Prompt 2 response"},"3":{"Display":"Prompt 3 response"},"4":{"Display":"Prompt 4 response"},"5":{"Display":"Prompt 5 response"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"Labels":[],"QuestionText_Unsafe":"Please rate the quality of each of chatbot's responses to all five prompts.<br><br>(0 = meaningless response, 100 = perfect response, as far as you can tell)<br>","DataExportTag":"Q50","QuestionID":"QID50"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"You will now be asked to complete the exact same task, but using a different chatbot on a differe...","TertiaryAttribute":null,"Payload":{"QuestionText":"You will now be asked to complete the exact same task, but using a different chatbot on a different website.<br><br>Please close the tab with the chatbot that you just finished interacting with.<br>","DefaultChoices":false,"DataExportTag":"Q27","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will now be asked to complete the exact same task, but using a different chatbot on a differe...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID51"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID52","SecondaryAttribute":"What is your highest education level completed?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your highest education level completed?","DefaultChoices":false,"DataExportTag":"Q28","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your highest education level completed?","Choices":{"1":{"Display":"No formal qualifications"},"2":{"Display":"Secondary education (e.g. GED\/GCSE)"},"3":{"Display":"High school diploma\/A-levels"},"4":{"Display":"Technical\/community college"},"5":{"Display":"Undergraduate degree (BA\/BSc\/other)"},"6":{"Display":"Graduate degree (MA\/MSc\/MPhil\/other)"},"7":{"Display":"Doctorate degree (PhD\/other)"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID52"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"SQ","PrimaryAttribute":"QID7","SecondaryAttribute":"You will be interacting with an AI chatbot through other websites. You are encouraged to interact...","TertiaryAttribute":null,"Payload":{"QuestionText":"You will be interacting with an AI chatbot through other websites. You are encouraged to interact with it naturally.<br><br>Please paste the provided prompts in the chat window, <b>and\/or<\/b> use your own prompts. You will be provided with five sample prompts to give the chatbot, which will be randomly chosen from a set of real-world prompts that people have given chatbots before. You may use these prompts, <b>and\/or<\/b> choose your own. You may also give your own follow-up prompts to any initial responses; Each of these follow-ups will count as one of your five prompts per chatbot.<br><br>After the chatbot has finished responding to one of the five prompts, please <b>rate its response by returning to this Qualtrics survey<\/b> and completing the corresponding question.<br><br>The chatbot may take time to respond, and the chatbot's response is complete only when the text stops changing. As you will be instructed on the following pages of this survey, you will complete these evaluations for <b>two different chatbots<\/b>, each with its own website, using the same questions. Make sure to enter the same Prolific ID both times.<br><br>Click \"next\" to see the link to the first of the two chatbots that you will interact with.<br>","DefaultChoices":false,"DataExportTag":"Q7","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will be interacting with an AI chatbot through other websites. You are encouraged to interact...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID7"}},{"SurveyID":"SV_a2XmdZWs3nBQUFU","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}